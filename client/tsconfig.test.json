{
  // The client test project. Adds @types/node (node:test / node:assert) on top of the app's
  // DOM libs. Includes all of src so every module a test imports is compiled here (a composite
  // project must list every file it type-checks); the app project still governs the bundle.
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.test.tsbuildinfo",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "types": ["vite/client", "node"]
  },
  "include": ["src"]
}
