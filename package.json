{
  "name": "webdirstat",
  "private": true,
  "type": "module",
  "license": "MIT",
  "author": "Yuriy Alekseyev <treewyrm@gmail.com>",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "dev": "pnpm --parallel --filter ./server --filter ./client run dev",
    "build": "pnpm --filter ./client run build && pnpm --filter ./server run build",
    "start": "pnpm --filter ./server run start",
    "typecheck": "pnpm --filter ./shared --filter ./server --filter ./client run typecheck",
    "lint": "pnpm --filter ./server --filter ./client run lint",
    "test": "node --import tsx --test \"{shared,server,client}/**/*.test.ts\"",
    "test:watch": "node --import tsx --test --watch \"{shared,server,client}/**/*.test.ts\"",
    "test:cov": "node --import tsx --test --experimental-test-coverage \"{shared,server,client}/**/*.test.ts\""
  },
  "devDependencies": {
    "tsx": "^4.19.2"
  }
}
